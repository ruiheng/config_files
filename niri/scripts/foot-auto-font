#!/bin/sh

set -eu

FOOT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/foot/foot.ini"
DEFAULT_POINT_SIZE_BASE="14"
LOW_DENSITY_MULTIPLIER="1.00"
MEDIUM_DENSITY_MULTIPLIER="1.08"
HIGH_DENSITY_MULTIPLIER="1.15"

# This script only reads font= from the main foot.ini file. If your active
# font is defined via include=, keep that font definition in foot.ini instead.

has_foot_server_socket() {
    if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -n "${WAYLAND_DISPLAY:-}" ] && [ -S "$XDG_RUNTIME_DIR/foot-$WAYLAND_DISPLAY.sock" ]; then
        return 0
    fi

    if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -S "$XDG_RUNTIME_DIR/foot.sock" ]; then
        return 0
    fi

    [ -S /tmp/foot.sock ]
}

get_size_multiplier() {
    output_json="$(niri msg -j focused-output 2>/dev/null || true)"

    if [ -z "$output_json" ]; then
        printf '%s\n' "$LOW_DENSITY_MULTIPLIER"
        return
    fi

    width="$(printf '%s' "$output_json" | jq -r '.logical.width // .modes[.current_mode].width // empty' 2>/dev/null || true)"
    height="$(printf '%s' "$output_json" | jq -r '.logical.height // .modes[.current_mode].height // empty' 2>/dev/null || true)"

    case "$width:$height" in
        ''|:*|*:)
            printf '%s\n' "$LOW_DENSITY_MULTIPLIER"
            return
            ;;
    esac

    if [ "$width" -ge 3840 ] || [ "$height" -ge 2160 ]; then
        printf '%s\n' "$HIGH_DENSITY_MULTIPLIER"
    elif [ "$width" -ge 2560 ] || [ "$height" -ge 1440 ]; then
        printf '%s\n' "$MEDIUM_DENSITY_MULTIPLIER"
    else
        printf '%s\n' "$LOW_DENSITY_MULTIPLIER"
    fi
}

read_base_font() {
    if [ ! -r "$FOOT_CONFIG" ]; then
        return
    fi

    font="$(
        awk '
            BEGIN {
                in_main = 1
                font = ""
            }

            /^[[:space:]]*#/ {
                next
            }

            /^[[:space:]]*\[/ {
                in_main = ($0 ~ /^[[:space:]]*\[main\][[:space:]]*$/)
                next
            }

            !in_main {
                next
            }

            /^[[:space:]]*font[[:space:]]*=/ {
                value = $0
                sub(/^[[:space:]]*font[[:space:]]*=[[:space:]]*/, "", value)
                sub(/[[:space:]]+$/, "", value)
                font = value
            }

            END {
                print font
            }
        ' "$FOOT_CONFIG"
    )"

    printf '%s\n' "$font"
}

scale_numeric_value() {
    value="$1"
    multiplier="$2"

    awk -v value="$value" -v multiplier="$multiplier" '
        BEGIN {
            scaled = value * multiplier
            formatted = sprintf("%.2f", scaled)
            sub(/0+$/, "", formatted)
            sub(/\.$/, "", formatted)
            print formatted
        }
    '
}

apply_multiplier() {
    font="$1"
    multiplier="$2"

    if printf '%s\n' "$font" | grep -Eq '(^|:)size=[0-9]+([.][0-9]+)?'; then
        key="size"
    elif printf '%s\n' "$font" | grep -Eq '(^|:)pixelsize=[0-9]+([.][0-9]+)?'; then
        printf '%s\n' "$font"
        return
    else
        scaled_value="$(scale_numeric_value "$DEFAULT_POINT_SIZE_BASE" "$multiplier")"
        printf '%s:size=%s\n' "$font" "$scaled_value"
        return
    fi

    current_value="$(
        printf '%s\n' "$font" \
            | grep -Eo "(^|:)$key=[0-9]+([.][0-9]+)?" \
            | head -n 1 \
            | sed -E "s/^:?$key=//"
    )"
    scaled_value="$(scale_numeric_value "$current_value" "$multiplier")"

    printf '%s\n' "$font" | sed -E "s/(^|:)$key=[0-9]+([.][0-9]+)?/\\1$key=$scaled_value/"
}

size_multiplier="$(get_size_multiplier)"
base_font="$(read_base_font)"

launch_cmd() {
    if has_foot_server_socket && footclient -N -E -a foot "$@" >/dev/null 2>&1; then
        exit 0
    fi

    exec foot -a foot "$@"
}

if [ -n "$base_font" ]; then
    resolved_font="$(apply_multiplier "$base_font" "$size_multiplier")"
    launch_cmd -o "main.font=$resolved_font" "$@"
fi

launch_cmd "$@"
