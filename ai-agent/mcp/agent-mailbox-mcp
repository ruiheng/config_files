#!/usr/bin/env node

const { spawn, spawnSync } = require("node:child_process");
const { realpathSync, statSync } = require("node:fs");
const path = require("node:path");
const { McpServer } = require("@modelcontextprotocol/sdk/server/mcp.js");
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js");
const z = require("zod");

const REPO_ROOT = path.resolve(__dirname, "..", "..");
const ACTIVE_SESSION_STATUSES = new Set(["running", "waiting", "idle"]);
const SYNC_CMD_TIMEOUT_MS = 30000;
const ENSURE_SESSION_SHOW_TIMEOUT_MS = 30000;

const STATE = {
  bound_addresses: [],
  default_sender: null,
  default_workdir: null,
  auto_bind_attempted: false,
  detected_agent_deck_session_id: null,
  detected_agent_session_id: null,
};

const DEFAULT_NOTIFY_MESSAGE =
  "Use the check-agent-mail skill now. Receive the pending message and execute its requested action.";

const SERVER_INSTRUCTIONS =
  "Bootstrap this MCP process once per agent-managed session. " +
  "If it is not bound yet, run `agent-deck session current --json`, take the current session id, and call `mailbox_bind`. " +
  "Use `agent-deck/<id>` as the default sender. " +
  "Use `agent_deck_create_session` only to allocate a new lifecycle-owned session. " +
  "Before sending mail to an existing target, call `agent_deck_require_session` with an explicit workdir to verify it still belongs to that workspace and start it if needed. " +
  "`mailbox_send` is transport-only and does not create sessions. " +
  "`mailbox_wait` is not recommended for normal workflow; prefer `mailbox_recv`. " +
  "Later reuse the bound addresses until MCP state is lost.";

function fail(message, data) {
  const error = new Error(message);
  error.data = data;
  throw error;
}

function runCmd(args, options = {}) {
  const {
    inputText = null,
    okCodes = [0],
    timeoutMs = SYNC_CMD_TIMEOUT_MS,
  } = options;

  const spawnOptions = {
    cwd: REPO_ROOT,
    encoding: "utf8",
    input: inputText,
  };
  if (typeof timeoutMs === "number") {
    spawnOptions.timeout = timeoutMs;
  }

  const proc = spawnSync(args[0], args.slice(1), spawnOptions);

  if (proc.error) {
    const detail = proc.error.code === "ETIMEDOUT" && typeof timeoutMs === "number"
      ? `timed out after ${timeoutMs}ms`
      : proc.error.message;
    fail(`command failed: ${args.join(" ")} :: ${detail}`, {
      args,
      returncode: proc.status,
    });
  }

  if (!okCodes.includes(proc.status)) {
    const detail =
      (proc.stderr || "").trim() ||
      (proc.stdout || "").trim() ||
      `exit code ${proc.status}`;
    fail(`command failed: ${args.join(" ")} :: ${detail}`, {
      args,
      returncode: proc.status,
    });
  }

  return proc;
}

function runProbe(args, options = {}) {
  const { timeoutMs = SYNC_CMD_TIMEOUT_MS, failOnError = false } = options;
  const spawnOptions = {
    cwd: REPO_ROOT,
    encoding: "utf8",
  };
  if (typeof timeoutMs === "number") {
    spawnOptions.timeout = timeoutMs;
  }
  const proc = spawnSync(args[0], args.slice(1), spawnOptions);
  if (proc.error) {
    if (failOnError) {
      const detail = proc.error.code === "ETIMEDOUT" && typeof timeoutMs === "number"
        ? `timed out after ${timeoutMs}ms`
        : proc.error.message;
      fail(`command failed: ${args.join(" ")} :: ${detail}`, {
        args,
        returncode: proc.status,
      });
    }
    return null;
  }
  return proc;
}

function runCmdAsync(args, options = {}) {
  const {
    inputText = null,
    okCodes = [0],
    signal = null,
    timeoutMs = null,
  } = options;

  return new Promise((resolve, reject) => {
    if (signal?.aborted) {
      reject(signal.reason || new Error("aborted"));
      return;
    }

    let proc = null;
    let timeoutHandle = null;

    let stdout = "";
    let stderr = "";
    let settled = false;

    const cleanupAbort = () => {
      if (signal) {
        signal.removeEventListener("abort", onAbort);
      }
      if (timeoutHandle) {
        clearTimeout(timeoutHandle);
        timeoutHandle = null;
      }
    };

    const finishReject = (error) => {
      if (settled) {
        return;
      }
      settled = true;
      cleanupAbort();
      reject(error);
    };

    const finishResolve = (value) => {
      if (settled) {
        return;
      }
      settled = true;
      cleanupAbort();
      resolve(value);
    };

    const onAbort = () => {
      try {
        proc?.kill("SIGTERM");
      } catch {
      }
      finishReject(signal?.reason || new Error("aborted"));
    };

    if (signal) {
      signal.addEventListener("abort", onAbort, { once: true });
    }

    proc = spawn(args[0], args.slice(1), {
      cwd: REPO_ROOT,
      stdio: "pipe",
    });

    if (typeof timeoutMs === "number") {
      timeoutHandle = setTimeout(() => {
        try {
          proc?.kill("SIGTERM");
        } catch {
        }
        finishReject(
          Object.assign(
            new Error(`command failed: ${args.join(" ")} :: timed out after ${timeoutMs}ms`),
            { data: { args, returncode: null } }
          )
        );
      }, timeoutMs);
    }

    if (signal?.aborted) {
      onAbort();
      return;
    }

    proc.stdout.setEncoding("utf8");
    proc.stderr.setEncoding("utf8");

    proc.stdout.on("data", (chunk) => {
      stdout += chunk;
    });
    proc.stderr.on("data", (chunk) => {
      stderr += chunk;
    });
    proc.on("error", (error) => {
      finishReject(error);
    });
    proc.on("close", (code) => {
      if (settled) {
        return;
      }
      if (!okCodes.includes(code)) {
        const detail =
          stderr.trim() ||
          stdout.trim() ||
          `exit code ${code}`;
        finishReject(
          Object.assign(new Error(`command failed: ${args.join(" ")} :: ${detail}`), {
            data: { args, returncode: code },
          })
        );
        return;
      }

      finishResolve({
        status: code,
        stdout,
        stderr,
      });
    });

    if (inputText !== null) {
      proc.stdin.write(inputText);
    }
    proc.stdin.end();
  });
}

function parseJsonOutput(text, context) {
  try {
    return JSON.parse(text);
  } catch (error) {
    fail(`${context} returned invalid JSON: ${error}`, { output: text });
  }
}

function dedupe(values) {
  const out = [];
  const seen = new Set();
  for (const value of values) {
    if (!value || seen.has(value)) {
      continue;
    }
    out.push(value);
    seen.add(value);
  }
  return out;
}

function parseAddress(address) {
  const match = /^([^/]+)\/(.+)$/.exec(address);
  if (!match) {
    fail(`invalid address: ${address}`);
  }
  return {
    scheme: match[1],
    id: match[2],
  };
}

function agentDeckAddress(sessionId) {
  return `agent-deck/${sessionId}`;
}

function codexAddress(sessionId) {
  return `codex/${sessionId}`;
}

function parsePsRow(text) {
  const trimmed = (text || "").trim();
  if (!trimmed) {
    return null;
  }
  const match = /^(\d+)\s+(\d+)\s+(\S+)\s*(.*)$/.exec(trimmed);
  if (!match) {
    return null;
  }
  return {
    pid: Number.parseInt(match[1], 10),
    ppid: Number.parseInt(match[2], 10),
    comm: match[3],
    args: match[4] || "",
  };
}

function getProcessRow(pid) {
  if (!pid || pid <= 1) {
    return null;
  }
  const proc = runProbe(["ps", "-p", String(pid), "-o", "pid=,ppid=,comm=,args="]);
  if (proc.status !== 0) {
    return null;
  }
  return parsePsRow(proc.stdout);
}

function extractCodexSessionIdFromArgs(args) {
  const match = /\bresume\s+([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\b/i.exec(args || "");
  return match ? match[1] : null;
}

function extractCodexSessionIdFromLsof(pid) {
  if (!pid || pid <= 1) {
    return null;
  }
  const proc = runProbe(["lsof", "-p", String(pid)]);
  if (proc.status !== 0) {
    return null;
  }
  const lines = proc.stdout.split("\n");
  for (const line of lines) {
    const match =
      /\/\.codex\/sessions\/.*-([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\.jsonl$/i.exec(
        line
      );
    if (match) {
      return match[1];
    }
  }
  return null;
}

function detectCurrentCodexSessionId() {
  const envSessionId = (process.env.CODEX_SESSION_ID || "").trim();
  if (envSessionId) {
    return envSessionId;
  }

  const seen = new Set();
  let pid = process.ppid;
  while (pid && pid > 1 && !seen.has(pid)) {
    seen.add(pid);
    const row = getProcessRow(pid);
    if (!row) {
      break;
    }
    const looksLikeCodex =
      row.comm === "codex" ||
      /(^|\/)codex(\s|$)/.test(row.args) ||
      row.args.includes("@openai/codex");
    if (looksLikeCodex) {
      const fromArgs = extractCodexSessionIdFromArgs(row.args);
      if (fromArgs) {
        return fromArgs;
      }
      const fromLsof = extractCodexSessionIdFromLsof(row.pid);
      if (fromLsof) {
        return fromLsof;
      }
      return null;
    }
    pid = row.ppid;
  }
  return null;
}

function mailboxAddresses(args = {}) {
  if (args.addresses && args.addresses.length > 0) {
    return dedupe(args.addresses);
  }
  const bound = getBoundState();
  if (bound.bound_addresses.length > 0) {
    return bound.bound_addresses.slice();
  }
  fail("no mailbox addresses provided and no mailbox addresses are bound");
}

function senderAddress(args = {}) {
  const bound = getBoundState();
  return args.from_address || bound.default_sender || bound.bound_addresses[0] || null;
}

function isLocalAddress(address) {
  return getBoundState().bound_addresses.includes(address);
}

function resolveSessionShow(identifier, options = {}) {
  const { timeoutMs = SYNC_CMD_TIMEOUT_MS } = options;
  const proc = runProbe(
    ["agent-deck", "session", "show", identifier, "--json"],
    { timeoutMs, failOnError: true }
  );
  if (!proc) {
    return null;
  }
  if (proc.status !== 0) {
    return null;
  }
  const data = parseJsonOutput(proc.stdout, "agent-deck session show");
  if (data && data.success === false) {
    return null;
  }
  return data;
}

function probeSessionShowBestEffort(identifier, options = {}) {
  const { timeoutMs = SYNC_CMD_TIMEOUT_MS } = options;
  const proc = runProbe(["agent-deck", "session", "show", identifier, "--json"], { timeoutMs });
  if (!proc) {
    return { status: "unknown", data: null };
  }
  if (proc.status !== 0) {
    const detail = `${proc.stderr || ""}\n${proc.stdout || ""}`.trim();
    if (/not found|no such session|unknown session/i.test(detail)) {
      return { status: "not_found", data: null };
    }
    return { status: "unknown", data: null };
  }
  const data = parseJsonOutput(proc.stdout, "agent-deck session show");
  if (data && data.success === false) {
    return { status: "not_found", data: null };
  }
  return { status: "found", data };
}

function resolveSessionShowBestEffort(identifier) {
  const probe = probeSessionShowBestEffort(identifier);
  return probe.status === "found" ? probe.data : null;
}

function tryAutoBindCurrentSession() {
  if (STATE.bound_addresses.length > 0 || STATE.auto_bind_attempted) {
    return;
  }

  const envAgentDeckId = (process.env.AGENTDECK_INSTANCE_ID || "").trim();
  let agentDeckSessionId = envAgentDeckId;
  let probeCompleted = Boolean(envAgentDeckId);
  if (!agentDeckSessionId) {
    const proc = runProbe(["agent-deck", "session", "current", "--json"]);
    probeCompleted = Boolean(proc);
    if (proc && proc.status === 0) {
      const data = parseJsonOutput(proc.stdout, "agent-deck session current");
      agentDeckSessionId = typeof data?.id === "string" ? data.id.trim() : "";
    }
  }

  const addresses = [];
  if (agentDeckSessionId) {
    STATE.detected_agent_deck_session_id = agentDeckSessionId;
    addresses.push(agentDeckAddress(agentDeckSessionId));
    const data = resolveSessionShowBestEffort(agentDeckSessionId);
    const workdir = typeof data?.path === "string" ? data.path.trim() : "";
    if (workdir) {
      STATE.default_workdir = workdir;
    }
  }

  const codexSessionId = detectCurrentCodexSessionId();
  if (codexSessionId) {
    STATE.detected_agent_session_id = codexSessionId;
    addresses.push(codexAddress(codexSessionId));
  }

  if (!probeCompleted && !codexSessionId && addresses.length === 0) {
    return;
  }

  STATE.bound_addresses = dedupe(addresses);
  if (agentDeckSessionId) {
    STATE.default_sender = agentDeckAddress(agentDeckSessionId);
  } else if (codexSessionId) {
    STATE.default_sender = codexAddress(codexSessionId);
  }
  STATE.auto_bind_attempted = true;
}

function getBoundState() {
  tryAutoBindCurrentSession();
  const warnings = [];
  if (!STATE.detected_agent_deck_session_id) {
    warnings.push("unable to determine current agent-deck session id");
  }
  if (!STATE.detected_agent_session_id) {
    warnings.push("unable to determine current AI agent session id");
  }
  if (STATE.bound_addresses.length === 0) {
    warnings.push("no mailbox addresses are currently bound");
  }
  return {
    bound_addresses: STATE.bound_addresses,
    default_sender: STATE.default_sender,
    default_workdir: STATE.default_workdir,
    detected_agent_deck_session_id: STATE.detected_agent_deck_session_id,
    detected_agent_session_id: STATE.detected_agent_session_id,
    warnings,
  };
}

function sessionInfoFromData(data, sessionRef = null) {
  if (!data) {
    return null;
  }
  const sessionId = data.id;
  if (typeof sessionId !== "string" || !sessionId) {
    return null;
  }
  return {
    session_id: sessionId,
    session_ref: sessionRef || data.title || sessionId,
    title: data.title || null,
    session_status: data.status || null,
    group: data.group || null,
    path: data.path || null,
    addresses: [agentDeckAddress(sessionId)],
  };
}

function validateExistingSessionWorkdir(data, workdir) {
  const existingPath = typeof data?.path === "string" ? data.path.trim() : "";
  if (!existingPath) {
    fail("existing session path unavailable: cannot verify workdir match");
  }
  const canonicalExistingPath = canonicalizeExistingPath(existingPath);
  if (canonicalExistingPath !== workdir) {
    fail(`session path mismatch: existing='${canonicalExistingPath}' expected='${workdir}'`);
  }
  return canonicalExistingPath;
}

function canonicalizeExistingPath(inputPath) {
  const absolutePath = path.resolve(String(inputPath || "").trim());
  const resolvedPath = realpathSync(absolutePath);
  const info = statSync(resolvedPath);
  if (!info.isDirectory()) {
    fail(`path is not a directory: ${inputPath}`);
  }
  return resolvedPath;
}

function sanitizeGroupSegment(value) {
  const normalized = String(value || "")
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9._@-]+/g, "-")
    .replace(/^-+|-+$/g, "");
  return normalized;
}

function buildChildGroupPath(parentGroup, childGroupName) {
  const parent = String(parentGroup || "").trim().replace(/\/+$/g, "");
  const child = sanitizeGroupSegment(childGroupName);
  if (!parent) {
    fail("cannot derive child group path without a parent group");
  }
  if (!child) {
    fail("child group name resolves to an empty segment");
  }
  return `${parent}/${child}`;
}

function buildEnsureSessionLaunchArgs({
  ensureTitle,
  ensureCmd,
  workdir,
  parentSessionId = null,
  noParentLink = false,
  listenerMessage = "",
  groupPath = null,
}) {
  const launchArgs = [
    "agent-deck",
    "launch",
    "--json",
    "--title",
    ensureTitle,
    "--cmd",
    ensureCmd,
  ];
  if (groupPath) {
    launchArgs.push("--group", groupPath);
  }
  if (noParentLink) {
    launchArgs.push("--no-parent");
  } else if (parentSessionId) {
    launchArgs.push("--parent", parentSessionId);
  }
  if (listenerMessage) {
    launchArgs.push("--message", listenerMessage);
  }
  launchArgs.push(workdir);
  return launchArgs;
}

function listGroupPaths() {
  const proc = runCmd(["agent-deck", "group", "list", "--json"]);
  const data = parseJsonOutput(proc.stdout, "agent-deck group list");
  return new Set(
    Array.isArray(data.groups)
      ? data.groups
          .map((group) => (typeof group.path === "string" ? group.path.trim() : ""))
          .filter(Boolean)
      : []
  );
}

async function ensureGroupPath(groupPath, extra) {
  const trimmed = String(groupPath || "").trim();
  if (!trimmed) {
    return null;
  }
  const existing = listGroupPaths();
  let current = "";
  for (const rawSegment of trimmed.split("/")) {
    const segment = rawSegment.trim();
    if (!segment) {
      fail(`invalid group path: ${groupPath}`);
    }
    const next = current ? `${current}/${segment}` : segment;
    if (!existing.has(next)) {
      const createArgs = ["agent-deck", "group", "create", segment];
      if (current) {
        createArgs.push("--parent", current);
      }
      await runCmdAsync(createArgs, {
        signal: extra?.signal,
      });
      existing.add(next);
    }
    current = next;
  }
  return trimmed;
}

function parseSendTokens(output) {
  const result = {
    delivery_id: null,
  };
  for (const token of output.split(/\s+/)) {
    if (token.startsWith("delivery_id=")) {
      result.delivery_id = token.slice("delivery_id=".length);
    }
  }
  return result;
}

function validateSendReceipt(ids, output) {
  const missing = [];
  if (!ids.delivery_id) {
    missing.push("delivery_id");
  }
  if (missing.length === 0) {
    return ids;
  }
  const detail = (output || "").trim() || "<empty stdout>";
  fail(`agent-mailbox send returned incomplete receipt: missing ${missing.join(", ")} :: ${detail}`, {
    missing,
    output,
  });
}

function hasItems(values) {
  return Array.isArray(values) && values.length > 0;
}

function forwardSubject(original, override) {
  const explicit = String(override || "").trim();
  if (explicit) {
    return explicit;
  }
  const base = String(original || "").trim();
  if (!base) {
    return "Fwd";
  }
  if (base.toLowerCase().startsWith("fwd:")) {
    return base;
  }
  return `Fwd: ${base}`;
}

function readSingleStoredMailboxItem({ messageId = null, deliveryId = null }) {
  const hasMessageId = Boolean(String(messageId || "").trim());
  const hasDeliveryId = Boolean(String(deliveryId || "").trim());
  if (hasMessageId === hasDeliveryId) {
    fail("mailbox_forward requires exactly one of message_id or delivery_id");
  }

  const cmd = ["agent-mailbox", "read"];
  const sourceKind = hasMessageId ? "message" : "delivery";
  const sourceId = hasMessageId ? String(messageId).trim() : String(deliveryId).trim();
  if (hasMessageId) {
    cmd.push("--message", sourceId);
  } else {
    cmd.push("--delivery", sourceId);
  }
  cmd.push("--json");

  const parsed = parseJsonOutput(runCmd(cmd).stdout, "agent-mailbox read");
  const items = Array.isArray(parsed?.items) ? parsed.items : [];
  if (items.length !== 1) {
    fail(`mailbox_forward source ${sourceKind} not found: ${sourceId}`);
  }
  return items[0];
}

function sendMailboxMessage(args) {
  const fromAddress = senderAddress(args);
  if (!fromAddress) {
    fail("mailbox_send requires from_address or a bound default_sender");
  }

  const contentType = args.content_type || "text/markdown";
  const schemaVersion = args.schema_version || "1";

  const sendProc = runCmd(
    [
      "agent-mailbox",
      "send",
      "--to",
      args.to_address,
      "--from",
      fromAddress,
      "--subject",
      args.subject,
      "--content-type",
      contentType,
      "--schema-version",
      schemaVersion,
      "--body-file",
      "-",
    ],
    { inputText: args.body }
  );
  const sendIds = validateSendReceipt(parseSendTokens(sendProc.stdout), sendProc.stdout);

  let notifyStatus = "skipped_local";
  let notifyScheme = null;
  const parsed = parseAddress(args.to_address);
  if (!isLocalAddress(args.to_address)) {
    switch (parsed.scheme) {
      case "agent-deck": {
        const notifyMessage = resolveWakeNotifyMessage(
          args.disable_notify_message,
          DEFAULT_NOTIFY_MESSAGE
        );
        if (!notifyMessage) {
          notifyStatus = "skipped_disabled";
          notifyScheme = parsed.scheme;
          break;
        }
        runCmd(["agent-deck", "session", "send", "--no-wait", parsed.id, notifyMessage]);
        notifyStatus = "sent";
        notifyScheme = parsed.scheme;
        break;
      }
      case "codex": {
        notifyStatus = "unsupported";
        notifyScheme = parsed.scheme;
        break;
      }
      default:
        notifyStatus = "unsupported";
        notifyScheme = parsed.scheme;
        break;
    }
  }

  return {
    status: "sent",
    from_address: fromAddress,
    to_address: args.to_address,
    subject: args.subject,
    delivery_id: sendIds.delivery_id,
    notify_status: notifyStatus,
    notify_scheme: notifyScheme,
  };
}

function inferTargetGroupPathFromParent(parentData, parentSessionId) {
  const parentGroup = typeof parentData?.group === "string" ? parentData.group.trim() : "";
  const ancestorSessionId =
    typeof parentData?.parent_session_id === "string" ? parentData.parent_session_id.trim() : "";
  if (!parentGroup || !ancestorSessionId) {
    return null;
  }
  const childGroupName =
    (typeof parentData?.title === "string" && parentData.title.trim()) ||
    String(parentSessionId || "").trim() ||
    (typeof parentData?.id === "string" ? parentData.id.trim() : "");
  return buildChildGroupPath(parentGroup, childGroupName);
}

function requireExplicitWorkdir(workdir) {
  const trimmed = String(workdir || "").trim();
  if (!trimmed) {
    fail("workdir is required");
  }
  return canonicalizeExistingPath(trimmed);
}

function resolveWakeNotifyMessage(disableNotifyMessage, defaultMessage = DEFAULT_NOTIFY_MESSAGE) {
  if (disableNotifyMessage === true) {
    return "";
  }
  return defaultMessage;
}

function makeToolResult(result) {
  return {
    content: [
      {
        type: "text",
        text: JSON.stringify(result, null, 2),
      },
    ],
    structuredContent: result,
  };
}

function presentBoundStateForStatus() {
  const bound = getBoundState();
  return {
    bound_addresses: bound.bound_addresses,
    default_sender: bound.default_sender || "<unset>",
    default_workdir: bound.default_workdir || "<unset>",
  };
}

function buildServer() {
  const server = new McpServer({
    name: "agent_mailbox",
    version: "0.4.0",
    instructions: SERVER_INSTRUCTIONS,
  });

  server.registerTool(
    "mailbox_bind",
    {
      description: "Bind one or more mailbox addresses into MCP server state.",
      inputSchema: {
        addresses: z.array(z.string()).min(1),
        default_sender: z.string().optional(),
        default_workdir: z.string().optional(),
      },
    },
    async ({ addresses, default_sender, default_workdir }) => {
      const boundAddresses = dedupe(addresses);
      const sender = default_sender || boundAddresses[0] || null;
      STATE.bound_addresses = boundAddresses;
      STATE.default_sender = sender;
      STATE.default_workdir = default_workdir || null;
      STATE.auto_bind_attempted = true;
      return makeToolResult({
        status: "bound",
        ...getBoundState(),
      });
    }
  );

  server.registerTool(
    "mailbox_status",
    {
      description: "Show the currently bound mailbox addresses, default sender, and default workdir stored in this MCP server.",
      inputSchema: {},
    },
    async () => makeToolResult(presentBoundStateForStatus())
  );

  server.registerTool(
    "mailbox_send",
    {
      description: "Send one mailbox message and automatically push-notify a non-local target when the address scheme supports it. Set disable_notify_message=true to skip notify for that send.",
      inputSchema: {
        to_address: z.string(),
        from_address: z.string().optional(),
        subject: z.string(),
        body: z.string(),
        content_type: z.string().optional(),
        schema_version: z.string().optional(),
        disable_notify_message: z.boolean().optional(),
      },
    },
    async (args) => makeToolResult(sendMailboxMessage(args))
  );

  server.registerTool(
    "mailbox_forward",
    {
      description: "Forward one stored mailbox message to a new recipient. Provide exactly one of message_id or delivery_id. The forward reuses the original body, content_type, and schema_version, and sends through the normal mailbox_send path.",
      inputSchema: {
        message_id: z.string().optional(),
        delivery_id: z.string().optional(),
        to_address: z.string(),
        from_address: z.string().optional(),
        subject: z.string().optional(),
        disable_notify_message: z.boolean().optional(),
      },
    },
    async (args) => {
      const source = readSingleStoredMailboxItem({
        messageId: args.message_id,
        deliveryId: args.delivery_id,
      });
      const result = sendMailboxMessage({
        to_address: args.to_address,
        from_address: args.from_address,
        subject: forwardSubject(source.subject, args.subject),
        body: typeof source.body === "string" ? source.body : "",
        content_type: source.content_type,
        schema_version: source.schema_version,
        disable_notify_message: args.disable_notify_message,
      });
      return makeToolResult({
        ...result,
        status: "forwarded",
        source_message_id: source.message_id || null,
        source_delivery_id: source.delivery_id || null,
      });
    }
  );

  server.registerTool(
    "mailbox_wait",
    {
      description: "Observe whether mail is available without claiming it. Not recommended for normal workflow; prefer mailbox_recv. Use this only for manual diagnostics or observation. Agent-managed session inbox addresses typically look like agent-deck/<session-id> or codex/<session-id>. Optional timeout is a duration string such as 30s, 5m, 120ms, or 1m30s.",
      inputSchema: {
        addresses: z.array(z.string()).optional(),
        timeout: z.string().optional(),
      },
    },
    async (args, extra) => {
      const addresses = mailboxAddresses(args);
      const cmd = ["agent-mailbox", "wait"];
      for (const address of addresses) {
        cmd.push("--for", address);
      }
      if (args.timeout) {
        cmd.push("--timeout", args.timeout);
      }
      cmd.push("--json");
      const proc = await runCmdAsync(cmd, {
        okCodes: [0, 2],
        signal: extra?.signal,
      });
      if (proc.status === 2) {
        return makeToolResult({
          status: "no_message",
          addresses,
        });
      }
      return makeToolResult({
        status: "message_available",
        addresses,
        delivery: parseJsonOutput(proc.stdout, "agent-mailbox wait"),
      });
    }
  );

  server.registerTool(
    "mailbox_recv",
    {
      description: "Receive mail immediately. If addresses is omitted, receive from all bound addresses; pass addresses only to override that inbox set for this call. After ack, use mailbox_read to reread persisted deliveries when context is lost.",
      inputSchema: {
        addresses: z.array(z.string()).optional(),
      },
    },
    async (args) => {
      const addresses = mailboxAddresses(args);
      const cmd = ["agent-mailbox", "recv"];
      for (const address of addresses) {
        cmd.push("--for", address);
      }
      cmd.push("--max", "1");
      cmd.push("--json");
      const proc = runCmd(cmd, { okCodes: [0, 2] });
      if (proc.status === 2) {
        return makeToolResult({
          status: "no_message",
          addresses,
        });
      }
      return makeToolResult({
        status: "received",
        addresses,
        delivery: parseJsonOutput(proc.stdout, "agent-mailbox recv"),
      });
    }
  );

  server.registerTool(
    "mailbox_list",
    {
      description: "List persisted deliveries for one inbox. Use state='acked' to find deliveries that were already received and acknowledged before rereading them with mailbox_read.",
      inputSchema: {
        address: z.string().optional(),
        as_person: z.string().optional(),
        state: z.string().optional(),
      },
    },
    async (args) => {
      const boundAddresses = args.address ? [] : mailboxAddresses();
      const address = args.address || (boundAddresses.length === 1 ? boundAddresses[0] : null);
      if (!address) {
        fail("mailbox_list requires address when multiple mailbox addresses are bound");
      }
      if (args.as_person && args.state) {
        fail("mailbox_list does not support state together with as_person");
      }

      const cmd = ["agent-mailbox", "list", "--for", address];
      if (args.as_person) {
        cmd.push("--as", args.as_person);
      }
      if (args.state) {
        cmd.push("--state", args.state);
      }
      cmd.push("--json");

      return makeToolResult({
        status: "listed",
        address,
        as_person: args.as_person || null,
        state: args.state || null,
        deliveries: parseJsonOutput(runCmd(cmd).stdout, "agent-mailbox list"),
      });
    }
  );

  server.registerTool(
    "mailbox_read",
    {
      description: "Read persisted mailbox messages or deliveries. Use latest=true with state='acked' to reread recently acknowledged mail after context loss.",
      inputSchema: {
        message_ids: z.array(z.string()).optional(),
        delivery_ids: z.array(z.string()).optional(),
        latest: z.boolean().optional(),
        addresses: z.array(z.string()).optional(),
        state: z.string().optional(),
        limit: z.number().int().positive().optional(),
      },
    },
    async (args) => {
      const hasMessageIds = hasItems(args.message_ids);
      const hasDeliveryIds = hasItems(args.delivery_ids);
      const wantsLatest = Boolean(args.latest);
      const modeCount = Number(hasMessageIds) + Number(hasDeliveryIds) + Number(wantsLatest);

      if (modeCount !== 1) {
        fail("mailbox_read requires exactly one mode: message_ids, delivery_ids, or latest=true");
      }

      const cmd = ["agent-mailbox", "read"];
      let result = {
        status: "read",
        mode: "unknown",
      };

      if (wantsLatest) {
        const addresses = mailboxAddresses(args);
        cmd.push("--latest");
        for (const address of addresses) {
          cmd.push("--for", address);
        }
        if (args.state) {
          cmd.push("--state", args.state);
        }
        if (typeof args.limit === "number") {
          cmd.push("--limit", String(args.limit));
        }
        result = {
          status: "read",
          mode: "latest",
          addresses,
          state: args.state || "any",
          limit: typeof args.limit === "number" ? args.limit : null,
        };
      } else if (hasMessageIds) {
        if (args.addresses || args.state || typeof args.limit === "number") {
          fail("mailbox_read message_ids mode does not support addresses, state, or limit");
        }
        const messageIds = dedupe(args.message_ids);
        for (const messageId of messageIds) {
          cmd.push("--message", messageId);
        }
        result = {
          status: "read",
          mode: "message_ids",
          message_ids: messageIds,
        };
      } else {
        if (args.addresses || args.state || typeof args.limit === "number") {
          fail("mailbox_read delivery_ids mode does not support addresses, state, or limit");
        }
        const deliveryIds = dedupe(args.delivery_ids);
        for (const deliveryId of deliveryIds) {
          cmd.push("--delivery", deliveryId);
        }
        result = {
          status: "read",
          mode: "delivery_ids",
          delivery_ids: deliveryIds,
        };
      }

      cmd.push("--json");
      return makeToolResult({
        ...result,
        ...parseJsonOutput(runCmd(cmd).stdout, "agent-mailbox read"),
      });
    }
  );

  server.registerTool(
    "mailbox_ack",
    {
      description: "Acknowledge a claimed mailbox delivery. Acked deliveries remain readable later through mailbox_read.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
      },
    },
    async ({ delivery_id, lease_token }) => {
      runCmd(["agent-mailbox", "ack", "--delivery", delivery_id, "--lease-token", lease_token]);
      return makeToolResult({ status: "acked", delivery_id });
    }
  );

  server.registerTool(
    "mailbox_release",
    {
      description: "Release a claimed mailbox delivery back to the queue.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
      },
    },
    async ({ delivery_id, lease_token }) => {
      runCmd(["agent-mailbox", "release", "--delivery", delivery_id, "--lease-token", lease_token]);
      return makeToolResult({ status: "released", delivery_id });
    }
  );

  server.registerTool(
    "mailbox_defer",
    {
      description: "Defer a claimed mailbox delivery until a later RFC3339 time.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
        until: z.string(),
      },
    },
    async ({ delivery_id, lease_token, until }) => {
      runCmd([
        "agent-mailbox",
        "defer",
        "--delivery",
        delivery_id,
        "--lease-token",
        lease_token,
        "--until",
        until,
      ]);
      return makeToolResult({ status: "deferred", delivery_id, until });
    }
  );

  server.registerTool(
    "mailbox_fail",
    {
      description: "Fail a claimed mailbox delivery with a reason.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
        reason: z.string(),
      },
    },
    async ({ delivery_id, lease_token, reason }) => {
      runCmd([
        "agent-mailbox",
        "fail",
        "--delivery",
        delivery_id,
        "--lease-token",
        lease_token,
        "--reason",
        reason,
      ]);
      return makeToolResult({ status: "failed", delivery_id, reason });
    }
  );

  server.registerTool(
    "agent_deck_resolve_session",
    {
      description: "Resolve an agent-deck session ref or id and return its canonical session id, status, and mailbox addresses.",
      inputSchema: {
        session: z.string(),
      },
    },
    async ({ session }) => {
      const data = resolveSessionShow(session);
      if (!data) {
        return makeToolResult({
          status: "not_found",
          session_ref: session,
        });
      }
      return makeToolResult({
        status: "found",
        ...sessionInfoFromData(data, session),
      });
    }
  );

  server.registerTool(
    "agent_deck_create_session",
    {
      description: "Create a new agent-deck session in an explicit workdir. Accepts create-only lifecycle parameters such as ensure_title, ensure_cmd, parent_session_id, group_path, group_parent_session_id, child_group_name, and no_parent_link. If an exact same-title target already exists in the same workdir, treat that as an interrupted create-step retry and return the existing target so the caller can continue with mailbox_send.",
      inputSchema: {
        ensure_title: z.string(),
        ensure_cmd: z.string(),
        parent_session_id: z.string().optional(),
        group_path: z.string().optional(),
        group_parent_session_id: z.string().optional(),
        child_group_name: z.string().optional(),
        no_parent_link: z.boolean().optional(),
        workdir: z.string(),
        listener_message: z.string().optional(),
      },
    },
    async (args, extra) => {
      const workdir = requireExplicitWorkdir(args.workdir);
      const noParentLink = args.no_parent_link === true;
      const listenerMessage = (args.listener_message || "").trim();
      let targetGroupPath = (args.group_path || "").trim() || null;

      if (noParentLink && args.parent_session_id) {
        fail("no_parent_link cannot be combined with parent_session_id");
      }

      if (!targetGroupPath && args.group_parent_session_id) {
        const parentData = resolveSessionShow(args.group_parent_session_id, {
          timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS,
        });
        if (!parentData) {
          fail(`group_parent_session_id not found: ${args.group_parent_session_id}`);
        }
        const parentGroup = typeof parentData.group === "string" ? parentData.group.trim() : "";
        if (!parentGroup) {
          fail("group_parent_session_id must belong to a non-root group");
        }
        const childGroupName = (args.child_group_name || "").trim() || args.ensure_title;
        targetGroupPath = buildChildGroupPath(parentGroup, childGroupName);
      }
      if (!targetGroupPath && args.parent_session_id) {
        const parentData = resolveSessionShow(args.parent_session_id, {
          timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS,
        });
        if (!parentData) {
          fail(`parent_session_id not found: ${args.parent_session_id}`);
        }
        targetGroupPath = inferTargetGroupPathFromParent(parentData, args.parent_session_id) || null;
      }
      if (!args.parent_session_id && !targetGroupPath && !noParentLink) {
        fail("creating a target session requires either group_path/group_parent_session_id or parent_session_id");
      }

      const existing = resolveSessionShow(args.ensure_title, {
        timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS,
      });
      if (existing) {
        validateExistingSessionWorkdir(existing, workdir);
        if (targetGroupPath) {
          await ensureGroupPath(targetGroupPath, extra);
        }
        let data = existing;
        const existingGroup = typeof data.group === "string" ? data.group.trim() : "";
        if (targetGroupPath && existingGroup !== targetGroupPath) {
          await runCmdAsync(["agent-deck", "group", "move", data.id, targetGroupPath], {
            signal: extra?.signal,
          });
          data = resolveSessionShow(data.id, { timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS }) || data;
        }
        let startedSession = false;
        let notifyNeeded = false;
        let listenerStatus = "not_needed_existing_session";
        if (ACTIVE_SESSION_STATUSES.has(data.status || null)) {
          notifyNeeded = true;
        } else {
          const startArgs = ["agent-deck", "session", "start", "--json", data.id];
          if (listenerMessage) {
            startArgs.splice(4, 0, "-m", listenerMessage);
          }
          await runCmdAsync(startArgs, {
            signal: extra?.signal,
          });
          data = resolveSessionShow(data.id, { timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS }) || data;
          startedSession = true;
          listenerStatus = listenerMessage ? "started_waiting" : "started";
        }

        return makeToolResult({
          status: "ready",
          ...sessionInfoFromData(data, args.ensure_title),
          created_target: false,
          started_session: startedSession,
          notify_needed: notifyNeeded,
          listener_status: listenerStatus,
          reused_existing: true,
        });
      }
      if (targetGroupPath) {
        await ensureGroupPath(targetGroupPath, extra);
      }

      const launchArgs = buildEnsureSessionLaunchArgs({
        ensureTitle: args.ensure_title,
        ensureCmd: args.ensure_cmd,
        workdir,
        parentSessionId: args.parent_session_id || null,
        noParentLink,
        listenerMessage,
        groupPath: targetGroupPath,
      });
      const proc = await runCmdAsync(launchArgs, {
        signal: extra?.signal,
      });
      const data = parseJsonOutput(proc.stdout, "agent-deck launch");

      return makeToolResult({
        status: "created",
        ...sessionInfoFromData(data, args.ensure_title),
        created_target: true,
        started_session: true,
        notify_needed: false,
        listener_status: "started_waiting",
      });
    }
  );

  server.registerTool(
    "agent_deck_require_session",
    {
      description: "Require an existing agent-deck session in an explicit workdir. Resolves session_id or session_ref, verifies the existing session already matches the requested workdir, and starts it if it is inactive. Does not create sessions or accept create-only lifecycle parameters.",
      inputSchema: {
        session_id: z.string().optional(),
        session_ref: z.string().optional(),
        workdir: z.string(),
        listener_message: z.string().optional(),
      },
    },
    async (args, extra) => {
      const identifier = args.session_id || args.session_ref || null;
      if (!identifier) {
        fail("session_id or session_ref is required when requiring a target session");
      }
      const workdir = requireExplicitWorkdir(args.workdir);
      let data = resolveSessionShow(identifier, { timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS });
      if (!data) {
        fail(`target session not found: ${identifier}`);
      }

      const listenerMessage = (args.listener_message || "").trim();
      validateExistingSessionWorkdir(data, workdir);

      let startedSession = false;
      let notifyNeeded = false;
      let listenerStatus = "not_needed";
      if (ACTIVE_SESSION_STATUSES.has(data.status || null)) {
        notifyNeeded = true;
        listenerStatus = "not_needed_existing_session";
      } else {
        const startArgs = ["agent-deck", "session", "start", "--json", data.id];
        if (listenerMessage) {
          startArgs.splice(4, 0, "-m", listenerMessage);
        }
        await runCmdAsync(startArgs, {
          signal: extra?.signal,
        });
        data = resolveSessionShow(data.id, { timeoutMs: ENSURE_SESSION_SHOW_TIMEOUT_MS }) || data;
        startedSession = true;
        listenerStatus = listenerMessage ? "started_waiting" : "started";
      }

      return makeToolResult({
        status: "ready",
        ...sessionInfoFromData(data, args.session_ref || identifier),
        created_target: false,
        started_session: startedSession,
        notify_needed: notifyNeeded,
        listener_status: listenerStatus,
      });
    }
  );

  return server;
}

async function main() {
  const server = buildServer();
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

if (require.main === module) {
  main().catch((error) => {
    console.error(error && error.stack ? error.stack : String(error));
    process.exit(1);
  });
}

module.exports = {
  buildChildGroupPath,
  buildEnsureSessionLaunchArgs,
  canonicalizeExistingPath,
  forwardSubject,
  inferTargetGroupPathFromParent,
  requireExplicitWorkdir,
  resolveWakeNotifyMessage,
  sanitizeGroupSegment,
  parseSendTokens,
  validateExistingSessionWorkdir,
  validateSendReceipt,
};
