#!/usr/bin/env node

const { spawnSync } = require("node:child_process");
const { existsSync } = require("node:fs");
const path = require("node:path");
const { McpServer } = require("@modelcontextprotocol/sdk/server/mcp.js");
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js");
const z = require("zod");

const REPO_ROOT = path.resolve(__dirname, "..", "..");

const STATE = {
  bound_session_id: null,
  default_workdir: null,
};

const DEFAULT_LISTENER_MESSAGE =
  "Use the check-workflow-mail skill now with wait=True. " +
  "Watch for pending workflow mail for your current agent-deck session, " +
  "then receive it and execute its requested action.";

const DEFAULT_WAKE_MESSAGE =
  "Use the check-workflow-mail skill now. " +
  "Receive the pending message for your current agent-deck session and execute its requested action.";

function fail(message, data) {
  const error = new Error(message);
  error.data = data;
  throw error;
}

function runCmd(args, options = {}) {
  const {
    inputText = null,
    okCodes = [0],
  } = options;

  const proc = spawnSync(args[0], args.slice(1), {
    cwd: REPO_ROOT,
    encoding: "utf8",
    input: inputText,
  });

  if (!okCodes.includes(proc.status)) {
    const detail =
      (proc.stderr || "").trim() ||
      (proc.stdout || "").trim() ||
      `exit code ${proc.status}`;
    fail(`command failed: ${args.join(" ")} :: ${detail}`, {
      args,
      returncode: proc.status,
    });
  }

  return proc;
}

function parseJsonOutput(text, context) {
  try {
    return JSON.parse(text);
  } catch (error) {
    fail(`${context} returned invalid JSON: ${error}`, { output: text });
  }
}

function dedupe(values) {
  const out = [];
  const seen = new Set();
  for (const value of values) {
    if (!seen.has(value)) {
      out.push(value);
      seen.add(value);
    }
  }
  return out;
}

function mailboxAddresses(args) {
  const raw = args.addresses;
  if (raw) {
    return {
      addresses: dedupe(raw),
      resolvedSessionId: null,
    };
  }

  const sessionId = args.current_session_id || args.session_id || STATE.bound_session_id;
  if (!sessionId) {
    fail("no session_id provided and no bound workflow session is set");
  }

  return {
    addresses: [`agent-deck/${sessionId}`],
    resolvedSessionId: sessionId,
  };
}

function boundOrExplicitSessionId(args, field = "current_session_id") {
  return args[field] || STATE.bound_session_id || null;
}

function resolveSessionShow(identifier) {
  const proc = spawnSync("agent-deck", ["session", "show", identifier, "--json"], {
    cwd: REPO_ROOT,
    encoding: "utf8",
  });
  if (proc.status !== 0) {
    return null;
  }
  const data = parseJsonOutput(proc.stdout, "agent-deck session show");
  if (data && data.success === false) {
    return null;
  }
  return data;
}

function resolveSessionId(identifier) {
  const data = resolveSessionShow(identifier);
  const sessionId = data && data.id;
  return typeof sessionId === "string" && sessionId ? sessionId : null;
}

function getSessionStatus(identifier) {
  const data = resolveSessionShow(identifier);
  const status = data && data.status;
  return typeof status === "string" && status ? status : null;
}

function parseSendTokens(output) {
  const result = {
    message_id: null,
    delivery_id: null,
    blob_id: null,
  };
  for (const token of output.split(/\s+/)) {
    if (token.startsWith("message_id=")) {
      result.message_id = token.slice("message_id=".length);
    } else if (token.startsWith("delivery_id=")) {
      result.delivery_id = token.slice("delivery_id=".length);
    } else if (token.startsWith("blob_id=")) {
      result.blob_id = token.slice("blob_id=".length);
    }
  }
  return result;
}

function makeToolResult(result) {
  return {
    content: [
      {
        type: "text",
        text: JSON.stringify(result, null, 2),
      },
    ],
    structuredContent: result,
  };
}

function buildServer() {
  const server = new McpServer({
    name: "workflow_mailbox",
    version: "0.2.0",
  });

  server.registerTool(
    "workflow_bind_session",
    {
      description:
        "Bind one agent-deck session id into MCP server state so later workflow_wait/workflow_recv calls can omit it.",
      inputSchema: {
        session_id: z.string().optional(),
        current_session_id: z.string().optional(),
        default_workdir: z.string().optional(),
      },
    },
    async ({ session_id, current_session_id, default_workdir }) => {
      const sessionId = session_id || current_session_id;
      if (!sessionId) {
        fail("session_id is required");
      }
      STATE.bound_session_id = sessionId;
      STATE.default_workdir = default_workdir || null;
      return makeToolResult({
        status: "bound",
        bound_session_id: sessionId,
        default_workdir: STATE.default_workdir,
      });
    }
  );

  server.registerTool(
    "workflow_session_status",
    {
      description: "Show the currently bound agent-deck session id stored in this MCP server.",
      inputSchema: {},
    },
    async () =>
      makeToolResult({
        bound_session_id: STATE.bound_session_id,
        default_workdir: STATE.default_workdir,
      })
  );

  server.registerTool(
    "workflow_send",
    {
      description: "Send one workflow mailbox message and perform the normal start-or-nudge delivery sequence.",
      inputSchema: {
        from_session_id: z.string(),
        current_session_id: z.string().optional(),
        to_session_id: z.string().optional(),
        to_session_ref: z.string().optional(),
        ensure_target_title: z.string().optional(),
        ensure_target_cmd: z.string().optional(),
        parent_session_id: z.string().optional(),
        workdir: z.string().optional(),
        subject: z.string(),
        body: z.string(),
        content_type: z.string().optional(),
        schema_version: z.string().optional(),
        listener_message: z.string().optional(),
        wake_message: z.string().optional(),
        wake_delay_seconds: z.number().int().nonnegative().optional(),
      },
    },
    async (args) => {
      const fromSessionId = args.from_session_id;
      const currentSessionId = boundOrExplicitSessionId(args);
      if (!currentSessionId) {
        fail("workflow_send requires current_session_id or a prior workflow_bind_session");
      }

      let toSessionId = args.to_session_id || null;
      let toSessionRef = args.to_session_ref || null;
      const ensureTargetTitle = args.ensure_target_title || null;
      const ensureTargetCmd = args.ensure_target_cmd || null;
      const parentSessionId = args.parent_session_id || null;
      const workdir = args.workdir || STATE.default_workdir || null;
      const contentType = args.content_type || "text/markdown";
      const schemaVersion = args.schema_version || "1";
      const listenerMessage = args.listener_message || DEFAULT_LISTENER_MESSAGE;
      const wakeMessage = args.wake_message || DEFAULT_WAKE_MESSAGE;
      const wakeDelaySeconds = args.wake_delay_seconds ?? 10;

      let createdTarget = false;

      if (!toSessionId && toSessionRef) {
        toSessionId = resolveSessionId(toSessionRef);
      }

      if (!toSessionId) {
        if (!ensureTargetTitle) {
          fail("target session missing: provide to_session_id, to_session_ref, or ensure_target_title");
        }
        if (!ensureTargetCmd) {
          fail("ensure_target_cmd is required when creating target session");
        }
        if (!parentSessionId) {
          fail("parent_session_id is required when creating target session");
        }
        if (!workdir) {
          fail("workdir is required when creating a target session");
        }
        if (!existsSync(workdir)) {
          fail(`workdir does not exist: ${workdir}`);
        }

        const proc = runCmd([
          "agent-deck",
          "launch",
          "--json",
          "--title",
          ensureTargetTitle,
          "--parent",
          parentSessionId,
          "--cmd",
          ensureTargetCmd,
          "--message",
          listenerMessage,
          workdir,
        ]);
        const createData = parseJsonOutput(proc.stdout, "agent-deck launch");
        const createdSessionId = createData && createData.id;
        if (typeof createdSessionId !== "string" || !createdSessionId) {
          fail("failed to parse created target session id", createData);
        }
        toSessionId = createdSessionId;
        if (!toSessionRef) {
          toSessionRef = ensureTargetTitle;
        }
        createdTarget = true;
      }

      if (!toSessionRef) {
        toSessionRef = toSessionId;
      }

      let body = args.body;
      body = body.replaceAll("{{FROM_SESSION_ID}}", fromSessionId);
      body = body.replaceAll("{{TO_SESSION_ID}}", toSessionId);
      body = body.replaceAll("{{TO_SESSION_REF}}", toSessionRef);

      const fromAddress = `agent-deck/${fromSessionId}`;
      const toAddress = `agent-deck/${toSessionId}`;

      let startStatus = "skipped_same_session";
      let listenerStatus = "skipped_same_session";
      let wakeupStatus = "skipped_same_session";
      let nudgeAfterSend = false;

      if (currentSessionId !== toSessionId) {
        if (createdTarget) {
          startStatus = "started";
          listenerStatus = "started_waiting";
        } else {
          const targetStatus = getSessionStatus(toSessionId);
          if (["running", "waiting", "idle"].includes(targetStatus)) {
            startStatus = `already_${targetStatus}`;
            listenerStatus = "not_needed_existing_session";
            nudgeAfterSend = true;
          } else {
            runCmd([
              "agent-deck",
              "session",
              "start",
              "--json",
              "-m",
              listenerMessage,
              toSessionId,
            ]);
            startStatus = "started";
            listenerStatus = "started_waiting";
          }
        }
      }

      const sendProc = runCmd(
        [
          "agent-mailbox",
          "send",
          "--to",
          toAddress,
          "--from",
          fromAddress,
          "--subject",
          args.subject,
          "--content-type",
          contentType,
          "--schema-version",
          schemaVersion,
          "--body-file",
          "-",
        ],
        { inputText: body }
      );
      const sendIds = parseSendTokens(sendProc.stdout);

      if (nudgeAfterSend) {
        if (wakeDelaySeconds > 0) {
          Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, wakeDelaySeconds * 1000);
        }
        runCmd(["agent-deck", "session", "send", "--no-wait", toSessionId, wakeMessage]);
        wakeupStatus = "sent";
      }

      return makeToolResult({
        from_session_id: fromSessionId,
        current_session_id: currentSessionId,
        to_session_id: toSessionId,
        to_session_ref: toSessionRef,
        created_target: createdTarget,
        subject: args.subject,
        message_id: sendIds.message_id,
        delivery_id: sendIds.delivery_id,
        blob_id: sendIds.blob_id,
        start_status: startStatus,
        listener_status: listenerStatus,
        wakeup_status: wakeupStatus,
        wake_delay_seconds: wakeDelaySeconds,
      });
    }
  );

  server.registerTool(
    "workflow_wait",
    {
      description:
        "Observe whether workflow mail is available for the bound session, an explicit session, or explicit addresses without claiming it.",
      inputSchema: {
        current_session_id: z.string().optional(),
        session_id: z.string().optional(),
        addresses: z.array(z.string()).optional(),
        timeout: z.string().optional(),
      },
    },
    async (args) => {
      const { addresses, resolvedSessionId } = mailboxAddresses(args);
      const cmd = ["agent-mailbox", "wait"];
      for (const address of addresses) {
        cmd.push("--for", address);
      }
      if (args.timeout) {
        cmd.push("--timeout", args.timeout);
      }
      cmd.push("--json");
      const proc = runCmd(cmd, { okCodes: [0, 2] });
      if (proc.status === 2) {
        return makeToolResult({
          status: "no_message",
          current_session_id: resolvedSessionId,
          addresses,
        });
      }
      return makeToolResult({
        status: "message_available",
        current_session_id: resolvedSessionId,
        addresses,
        delivery: parseJsonOutput(proc.stdout, "agent-mailbox wait"),
      });
    }
  );

  server.registerTool(
    "workflow_recv",
    {
      description:
        "Receive workflow mail for the bound session, an explicit session, or explicit addresses. With wait=true, first wait for mail to appear, then claim it once.",
      inputSchema: {
        current_session_id: z.string().optional(),
        session_id: z.string().optional(),
        addresses: z.array(z.string()).optional(),
        wait: z.boolean().optional(),
        timeout: z.string().optional(),
      },
    },
    async (args) => {
      const { addresses, resolvedSessionId } = mailboxAddresses(args);
      if (args.wait) {
        const waitResult = await server.server.callTool({
          name: "workflow_wait",
          arguments: {
            addresses,
            timeout: args.timeout,
          },
        });
        const structured = waitResult.structuredContent;
        if (structured && structured.status === "no_message") {
          return waitResult;
        }
      }

      const cmd = ["agent-mailbox", "recv"];
      for (const address of addresses) {
        cmd.push("--for", address);
      }
      cmd.push("--json");
      const proc = runCmd(cmd, { okCodes: [0, 2] });
      if (proc.status === 2) {
        return makeToolResult({
          status: "no_message",
          current_session_id: resolvedSessionId,
          addresses,
        });
      }
      return makeToolResult({
        status: "received",
        current_session_id: resolvedSessionId,
        addresses,
        delivery: parseJsonOutput(proc.stdout, "agent-mailbox recv"),
      });
    }
  );

  server.registerTool(
    "workflow_ack",
    {
      description: "Acknowledge a claimed workflow delivery.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
      },
    },
    async ({ delivery_id, lease_token }) => {
      runCmd(["agent-mailbox", "ack", "--delivery", delivery_id, "--lease-token", lease_token]);
      return makeToolResult({ status: "acked", delivery_id });
    }
  );

  server.registerTool(
    "workflow_release",
    {
      description: "Release a claimed workflow delivery back to the queue.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
      },
    },
    async ({ delivery_id, lease_token }) => {
      runCmd(["agent-mailbox", "release", "--delivery", delivery_id, "--lease-token", lease_token]);
      return makeToolResult({ status: "released", delivery_id });
    }
  );

  server.registerTool(
    "workflow_defer",
    {
      description: "Defer a claimed workflow delivery until a later RFC3339 time.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
        until: z.string(),
      },
    },
    async ({ delivery_id, lease_token, until }) => {
      runCmd([
        "agent-mailbox",
        "defer",
        "--delivery",
        delivery_id,
        "--lease-token",
        lease_token,
        "--until",
        until,
      ]);
      return makeToolResult({ status: "deferred", delivery_id, until });
    }
  );

  server.registerTool(
    "workflow_fail",
    {
      description: "Fail a claimed workflow delivery with a reason.",
      inputSchema: {
        delivery_id: z.string(),
        lease_token: z.string(),
        reason: z.string(),
      },
    },
    async ({ delivery_id, lease_token, reason }) => {
      runCmd([
        "agent-mailbox",
        "fail",
        "--delivery",
        delivery_id,
        "--lease-token",
        lease_token,
        "--reason",
        reason,
      ]);
      return makeToolResult({ status: "failed", delivery_id, reason });
    }
  );

  return server;
}

async function main() {
  const server = buildServer();
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

main().catch((error) => {
  console.error(error && error.stack ? error.stack : String(error));
  process.exit(1);
});
